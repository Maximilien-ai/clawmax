# System model keys — used by dashboard-owned/system actions.
# Examples: generating agents, generating workflows, cron/system agents, and future platform automations.
# These keys are read from SYSTEM/dashboard/.env, not from shell exports like ~/.zshrc.
SYSTEM_OPENAI_API_KEY=sk-your-system-openai-key-here
SYSTEM_ANTHROPIC_API_KEY=sk-ant-your-system-anthropic-key-here
# Legacy names are still supported if they are set in this file:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional default end-user model keys.
# If set, these are the default execution keys for logged-in users until BYOK is captured in-app.
# By default, user agents/workflows do NOT fall back to system keys unless ALLOW_SYSTEM_KEYS_FOR_USER_EXECUTION=true.
# USER_OPENAI_API_KEY=
# USER_ANTHROPIC_API_KEY=
# USER_NEBIUS_API_KEY=
# ALLOW_SYSTEM_KEYS_FOR_USER_EXECUTION=false

# Senso (optional — shared context / knowledge layer for agents)
# Used for multimodal ingest, search, generation, and MCP-based context access.
# SENSO_API_KEY=

# Comet Opik (optional — for token metering)
OPIK_API_KEY=your-opik-key-here
OPIK_WORKSPACE="your-workspace"
OPIK_PROJECT_NAME="ClawMax.ai - dev"

# ClawMax Dashboard Environment
OPENCLAW_WORKSPACE=/path/to/your/workspace
NODE_ENV=development
DASHBOARD_PORT=3001
CORS_ORIGIN=http://localhost:5173
# Optional extra template roots, separated by ':' on macOS/Linux or ';' on Windows.
# Each root may contain:
# - agents/ and organizations/ subdirectories, or
# - a flat directory of organization template folders (useful for private enterprise template repos)
# CLAWMAX_EXTRA_TEMPLATE_DIRS=/opt/clawmax-enterprise/templates
# Optional extra partner roots, comma-separated.
# Each root may contain partner folders like PARTNERS/<slug>/partner.json.
# CLAWMAX_EXTRA_PARTNER_DIRS=/opt/clawmax-partners,/opt/private-partners
# Control which partner integration pages appear in Workspaces Integrations.
# Example: WORKSPACES_INTEGRATIONS_THIRD_PARTIES=senso,opik,github,blaxel,redis
# WORKSPACES_INTEGRATIONS_THIRD_PARTIES=senso,opik,github
# Control whether Ollama appears in Workspaces Integrations and model-selection UI.
# Default behavior:
# - local / on-prem with dashboard .env present: enabled
# - managed / cloud runtime with no dashboard .env: hidden
# Set explicitly to true to force-enable it, or false to force-hide it.
# DASHBOARD_ENABLE_OLLAMA=false
# DASHBOARD_PUBLIC_URL=http://localhost:3001  # Optional: force OAuth callback/session origin
# DASHBOARD_APP_URL=http://localhost:5173      # Optional: force post-login/logout redirect target
# DASHBOARD_TRUST_PROXY=false                 # Set true behind a trusted reverse proxy

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
# Select dashboard auth mode:
# - github_oauth  : GitHub OAuth only
# - email_otp     : email login code only
# - bypass        : no auth (local-only)
# If omitted, the dashboard defaults to github_oauth.
# Valid values: github_oauth | email_otp | bypass
# DASHBOARD_AUTH_MODE=github_oauth

# Set BYPASS_OAUTH=true only for solo/local development when you do not need auth.
# WARNING: Do NOT enable in production or shared deployments.
BYPASS_OAUTH=true

# GitHub OAuth (required when BYPASS_OAUTH is false)
# Create at: GitHub > Settings > Developer settings > OAuth Apps
# Callback URL: http://localhost:3001/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_ALLOWED_USERS=yourgithublogin  # Optional: comma-separated allowed logins
# JWT_SECRET=replace-with-a-long-random-secret  # Recommended for stable session signing

# Email OTP (single-user cloud / on-prem / local dev)
# DASHBOARD_AUTH_MODE=email_otp
# OTP_ALLOWED_EMAILS=you@example.com
# OTP_EXPIRY_MINUTES=15
# OTP_FROM_EMAIL=ClawMax <onboarding@your-verified-domain.com>
# Optional fallback shared sender if OTP_FROM_EMAIL is unset:
# SIGNUP_FROM_EMAIL=ClawMax <onboarding@your-verified-domain.com>
# OTP_EMAIL_SUBJECT=Your ClawMax login code
# For explicit OTP log mode, log the OTP to the main server output instead of sending:
# Valid value: log
# Any other value, or leaving it unset, disables OTP log mode.
# OTP_DEV_MODE=log
# For production delivery via Resend:
# RESEND_API_KEY=re_xxx

# Ngrok tunnel (optional, for --ngrok flag)
# NGROK_URL=yoursubdomain.ngrok.dev
