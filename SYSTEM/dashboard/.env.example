# System model keys — used by dashboard-owned/system actions.
# Examples: generating agents, generating workflows, cron/system agents, and future platform automations.
# These keys are read from SYSTEM/dashboard/.env, not from shell exports like ~/.zshrc.
SYSTEM_OPENAI_API_KEY=sk-your-system-openai-key-here
SYSTEM_ANTHROPIC_API_KEY=sk-ant-your-system-anthropic-key-here
# Legacy names are still supported if they are set in this file:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional default end-user model keys.
# If set, these are the default execution keys for logged-in users until BYOK is captured in-app.
# By default, user agents/workflows do NOT fall back to system keys unless ALLOW_SYSTEM_KEYS_FOR_USER_EXECUTION=true.
# USER_OPENAI_API_KEY=
# USER_ANTHROPIC_API_KEY=
# USER_NEBIUS_API_KEY=
# ALLOW_SYSTEM_KEYS_FOR_USER_EXECUTION=false

# Comet Opik (optional — for token metering)
OPIK_API_KEY=your-opik-key-here
OPIK_WORKSPACE="your-workspace"
OPIK_PROJECT_NAME="ClawMax.ai - dev"

# ClawMax Dashboard Environment
OPENCLAW_WORKSPACE=/path/to/your/workspace
NODE_ENV=development
DASHBOARD_PORT=3001
CORS_ORIGIN=http://localhost:5173
# DASHBOARD_PUBLIC_URL=http://localhost:3001  # Optional: force OAuth callback/session origin
# DASHBOARD_APP_URL=http://localhost:5173      # Optional: force post-login/logout redirect target
# DASHBOARD_TRUST_PROXY=false                 # Set true behind a trusted reverse proxy

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
# Set BYPASS_OAUTH=true to skip GitHub OAuth entirely.
# Use this for solo/local development when you don't need authentication.
# WARNING: Do NOT enable in production or shared deployments — all API
# endpoints will be accessible without login.
# Defaults to false (OAuth required).
BYPASS_OAUTH=true

# GitHub OAuth (required when BYPASS_OAUTH is false)
# Create at: GitHub > Settings > Developer settings > OAuth Apps
# Callback URL: http://localhost:3001/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_ALLOWED_USERS=yourgithublogin  # Optional: comma-separated allowed logins
# JWT_SECRET=replace-with-a-long-random-secret  # Recommended for stable session signing

# Ngrok tunnel (optional, for --ngrok flag)
# NGROK_URL=yoursubdomain.ngrok.dev
