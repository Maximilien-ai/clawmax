{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "type", "version", "agents"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name of the template"
    },
    "type": {
      "const": "agent",
      "description": "Template type - must be 'agent' for single-agent templates"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "description": {
      "type": "string",
      "description": "What this agent template is for"
    },
    "author": {
      "type": "string",
      "description": "Template creator"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Searchable tags"
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "$ref": "#/definitions/agent" },
      "description": "Single agent definition"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "aiPrompt": {
          "type": "string",
          "description": "Original AI prompt used to create this agent"
        },
        "model": {
          "type": "string",
          "description": "LLM model used"
        },
        "createdAt": {
          "type": "string",
          "description": "When this template was created (ISO 8601 format)"
        },
        "updatedAt": {
          "type": "string",
          "description": "When this template was last updated (ISO 8601 format)"
        },
        "basedOnSlug": {
          "type": "string",
          "description": "Source template slug this workspace variant was based on"
        },
        "basedOnSource": {
          "type": "string",
          "enum": ["system", "workspace", "enterprise"],
          "description": "Source template type this workspace variant was based on"
        }
      }
    }
  },
  "definitions": {
    "agent": {
      "type": "object",
      "required": ["id", "role"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "Agent identifier (lowercase, alphanumeric, dashes, underscores)"
        },
        "name": {
          "type": "string",
          "description": "Human-readable agent name"
        },
        "role": {
          "type": "string",
          "description": "Agent role/purpose"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Agent tags"
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Referenced skill names (not file paths)"
        }
      }
    }
  }
}
