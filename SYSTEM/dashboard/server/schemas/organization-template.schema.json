{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "type", "version", "agents"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name of the template"
    },
    "type": {
      "const": "organization",
      "description": "Template type - must be 'organization' for multiagent templates"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "description": {
      "type": "string",
      "description": "What this organization template is for"
    },
    "author": {
      "type": "string",
      "description": "Template creator"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Searchable tags"
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/agent" },
      "description": "Agent definitions"
    },
    "communities": {
      "type": "array",
      "items": { "$ref": "#/definitions/community" },
      "description": "Community definitions"
    },
    "groups": {
      "type": "array",
      "items": { "$ref": "#/definitions/group" },
      "description": "Group definitions"
    },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agentId", "label", "default", "min", "max"],
        "properties": {
          "agentId": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "default": { "type": "integer", "minimum": 1, "maximum": 10 },
          "min": { "type": "integer", "minimum": 1, "maximum": 10 },
          "max": { "type": "integer", "minimum": 1, "maximum": 10 }
        }
      },
      "description": "Optional scalable agent-count controls for templated teams"
    },
    "workflows": {
      "type": "array",
      "items": { "$ref": "#/definitions/workflow" },
      "description": "Workflow definitions"
    }
  },
  "definitions": {
    "agent": {
      "type": "object",
      "required": ["id", "role"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "communities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Community names this agent belongs to"
        },
        "groups": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Group names this agent belongs to"
        }
      }
    },
    "community": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "channels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Communication channels: whatsapp, slack, etc."
        }
      }
    },
    "group": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "community": {
          "type": "string",
          "description": "Parent community name"
        },
        "channels": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "workflow": {
      "type": "object",
      "required": ["id", "name", "schedule", "executionMode", "targeting", "content"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "schedule": { "type": "string" },
        "enabled": { "type": "boolean" },
        "executionMode": {
          "type": "string",
          "enum": ["automated", "managed"]
        },
        "scaling": {
          "type": "string",
          "enum": ["singleton", "parallel"]
        },
        "parallelism": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string" }
        },
        "targeting": {
          "type": "object",
          "properties": {
            "communities": {
              "type": "array",
              "items": { "type": "string" }
            },
            "groups": {
              "type": "array",
              "items": { "type": "string" }
            },
            "tags": {
              "type": "array",
              "items": { "type": "string" }
            },
            "agents": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "content": { "type": "string" }
      }
    }
  }
}
