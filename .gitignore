# Runtime message archives
SYSTEM/messages/

# Workspace state (runtime)
**/.openclaw/workspace-state.json

# Node modules
node_modules/

# Build outputs
dist/

# Environment files
.env
.env.local

# Dashboard auth token
SYSTEM/dashboard/.dashboard-token
SYSTEM/dashboard/server/.dashboard-token

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store

# Agent workspace directories (generated at runtime)
AGENTS/*/
!AGENTS/max0/
!AGENTS/engineer/
!AGENTS/qa-engineer/
!AGENTS/ceo/

# Workflow executions (runtime data)
WORKFLOWS/executions/

# Template agent instances are committed (needed for org template apply)
TEMPLATES/organizations/qa-team/
# Note: User-created templates in workspace. Global system templates at ~/.openclaw/TEMPLATES/

# Workspace runtime data
WORKSPACES/

# Generated scripts
SYSTEM/scripts/
