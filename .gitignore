# Local agent state and Claude Code config
.agents/
.claude/

# Runtime message archives
SYSTEM/messages/

# Workspace state (runtime)
**/.openclaw/workspace-state.json

# Node modules
node_modules/

# Build outputs
dist/

# Environment files
.env
.env.local

# Dashboard auth token
SYSTEM/dashboard/.dashboard-token
SYSTEM/dashboard/server/.dashboard-token
SYSTEM/dashboard/server/data/auth/otp-store.json
.clawmax-otp-dev.json

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store

# Agent workspace directories (generated at runtime)
AGENTS/*/
!AGENTS/max0/
!AGENTS/engineer/
!AGENTS/qa-engineer/
!AGENTS/ceo/

# Workflow executions (runtime data)
WORKFLOWS/executions/

# Template agent instances are committed (needed for org template apply)
TEMPLATES/organizations/qa-team/
# Note: User-created templates in workspace. Global system templates at ~/.openclaw/TEMPLATES/

# Workspace runtime data
WORKSPACES/
!WORKSPACES/default/
WORKSPACES/default/*
!WORKSPACES/default/SKILLS/
WORKSPACES/default/SKILLS/*
!WORKSPACES/default/SKILLS/custom/
WORKSPACES/default/SKILLS/custom/*
!WORKSPACES/default/SKILLS/custom/.gitkeep

# Generated scripts
SYSTEM/scripts/
